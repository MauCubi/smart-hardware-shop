generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AttributeType {
  STRING
  NUMBER
  BOOLEAN
  SELECT
}

enum Rol {
  admin
  user
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  subCategories SubCategory[]
}

model SubCategory {
  id         String                 @id @default(uuid())
  name       String                 @unique
  products   Product[]
  category   Category               @relation(fields: [categoryId], references: [id])
  categoryId String
  attributes SubCategoryAttribute[]
}

model AttributeOption {
  id          String    @id @default(cuid())
  value       String
  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id])

  productAttributes ProductAttribute[]
}

model Attribute {
  id       String        @id @default(uuid())
  name     String        @unique
  type     AttributeType
  group    String
  unit     String?
  required Boolean       @default(false)

  options AttributeOption[]

  subCategories SubCategoryAttribute[]

  productAttributes ProductAttribute[]
}

model SubCategoryAttribute {
  subCategoryId String
  attributeId   String

  subCategory SubCategory @relation(fields: [subCategoryId], references: [id])
  attribute   Attribute   @relation(fields: [attributeId], references: [id])

  @@id([subCategoryId, attributeId])
}

model Product {
  id            String   @id @default(uuid())
  name          String
  description   String?
  stock         Int
  sku           String?
  price         Float    @default(0)
  discountPrice Float?
  slug          String   @unique
  images        String[] @default([])

  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id])
  subCategoryId String

  brands  Brand?  @relation(fields: [brandId], references: [id])
  brandId String

  productAttributes ProductAttribute[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
}

model Brand {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model ProductAttribute {
  id          Int    @id @default(autoincrement())
  productId   String
  attributeId String

  valueString  String?
  valueNumber  Float?
  valueBoolean Boolean?

  optionId String?

  product   Product          @relation(fields: [productId], references: [id])
  attribute Attribute        @relation(fields: [attributeId], references: [id])
  option    AttributeOption? @relation(fields: [optionId], references: [id])

  // @@id([productId, attributeId])

  @@unique([productId, attributeId])
}

model User {
  id          String    @id @default(uuid())
  name        String
  lastName    String
  email       String    @unique
  emailVerify DateTime?
  password    String
  rol         Rol       @default(user)
}
